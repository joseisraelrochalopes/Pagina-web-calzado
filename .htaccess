<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /mi_tienda/

# 1. Si el archivo existe físicamente, no hacer nada
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. REGLA MAESTRA (Aquí añadí el guion bajo "_")
# Antes: [a-zA-Z0-9-]  -> Ahora: [a-zA-Z0-9-_]
RewriteRule ^([a-zA-Z0-9-_]+)/([a-zA-Z0-9-_]+)/?$ index.php?controller=$1&action=$2 [QSA,L]

# 3. Regla para cuando solo hay controlador
RewriteRule ^([a-zA-Z0-9-_]+)/?$ index.php?controller=$1&action=index [QSA,L]

</IfModule>